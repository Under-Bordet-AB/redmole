{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"DEFAULT_MINIMUM_TOKENS": ""
			},
			"disabled": true,
			"alwaysAllow": [],
			"disabledTools": []
		},
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/home/gustav/Documents/"
			],
			"alwaysAllow": [
				"read_text_file",
				"read_multiple_files",
				"list_directory"
			],
			"disabled": true,
			"disabledTools": [
				"read_file"
			]
		},
		"sequentialthinking": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			],
			"disabled": true,
			"alwaysAllow": [],
			"disabledTools": [
				"sequentialthinking"
			]
		}
	}
}